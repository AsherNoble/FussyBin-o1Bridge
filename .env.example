# Copy this file to .env and adjust values for your setup.

# Serial device path for the ESP32-CAM
# (e.g. /dev/cu.usbserial-1130 on macOS, /dev/ttyUSB0 on Linux, COM3 on Windows).
FUSSYBIN_SERIAL_PORT=/dev/cu.usbserial-1130

# Baud rate for ESP32 serial communication.
FUSSYBIN_BAUD_RATE=115200

# Minimum softmax probability for a classification to be accepted.
# Predictions below this confidence are tagged "Unsure" instead of being routed to a bin.
FUSSYBIN_CONFIDENCE_THRESHOLD=0.15
